    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@rjsf/core": "^6.4.1",
    "@rjsf/shadcn": "^6.4.1",
    "@rjsf/utils": "^6.4.1",
    "@rjsf/validator-ajv8": "^6.4.1",
    "@tiptap/extension-mention": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "@tiptap/suggestion": "^2.27.2",
    "@vercel/blob": "^2.3.1",
    "@xyflow/react": "^12.10.1",
    "ai": "^5.0.157",
    "better-auth": "^1.5.6",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "consola": "^3.4.2",
    "date-fns": "^4.1.0",
    "deepmerge": "^4.3.1",
    "dify-ai-provider": "^1.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "emoji-picker-react": "^4.18.0",
    "framer-motion": "^12.38.0",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "ioredis": "^5.10.1",
    "json-schema": "^0.4.0",
    "katex": "^0.16.40",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.13.0",
    "nanoid": "^5.1.7",
    "next": "16.2.1",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "ollama-ai-provider-v2": "^1.5.5",
    "page-agent": "^1.6.1",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "qwen-ai-provider": "^0.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.9",
    "recharts": "^2.15.4",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "server-only": "^0.0.1",
    "shiki": "^3.23.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "ts-edge": "^1.0.4",
    "ts-safe": "^0.0.5",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zhipu-ai-provider": "^0.1.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@better-auth-kit/seed": "^1.0.12",
    "@biomejs/biome": "2.4.8",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "3.2.4"
  },
  "lint-staged": {
    "*.{js,json,mjs,ts,tsx,css}": [
      "pnpm format",
      "pnpm lint:fix"
    ],
    "*.{yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "ignoredBuiltDependencies": [
      "@swc/core"
    ]
  }
}
